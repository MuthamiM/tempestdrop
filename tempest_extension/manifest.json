{
    "manifest_version": 3,
    "name": "TempestDrop - AirGap Link",
    "version": "1.0",
    "description": "Secure Data Exfiltration POC using Physical Optical Side-Channels.",
    "permissions": [
        "activeTab",
        "scripting",
        "tabs"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}